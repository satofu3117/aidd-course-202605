# ============================================================================
#  AIDD Training - .gitignore
# ============================================================================

# ----- Gradle ---------------------------------------------------------------
.gradle/
.gradle-cache/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ----- Java -----------------------------------------------------------------
*.class
*.log
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ----- Spring Boot ----------------------------------------------------------
# Spring Boot DevTools のリスタートトリガーファイル
.restart-trigger
# 環境固有設定(本番接続情報など。研修では使わないが安全策として)
application-local.properties
application-local.yml
application-secret.properties

# ----- IDE: IntelliJ IDEA ---------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# ----- IDE: Eclipse / STS ---------------------------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/
bin/

# ----- IDE: VS Code ---------------------------------------------------------
.vscode/
*.code-workspace

# ----- IDE: NetBeans --------------------------------------------------------
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ----- macOS / Linux / Windows ----------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- Claude Code ----------------------------------------------------------
#  ⚠️ .claude/settings.json は研修配布物なので Git 管理対象に残します。
#     個人ごとの上書きは settings.local.json に書く運用としてください。
.claude/settings.local.json
.claude/cache/
.claude/logs/
CLAUDE.local.md

# ----- 環境変数・秘密情報 ---------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ----- 一時ファイル ---------------------------------------------------------
*.tmp
*.bak
*.swp
*~
