{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "additionalDirectories": [],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ..*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(dd if=*)",
      "Bash(mkfs *)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(eval *)",
      "Bash(* > /etc/*)",
      "Bash(* >> /etc/*)",
      "Bash(* > ~/.bashrc*)",
      "Bash(* > ~/.zshrc*)",
      "Bash(* > ~/.profile*)",
      "Bash(* > ~/.bash_profile*)",
      "Bash(* ~/.ssh*)",
      "Bash(* /Users/*/.ssh*)",
      "Bash(* /home/*/.ssh*)",
      "Bash(* ~/.aws*)",
      "Bash(* /Users/*/.aws*)",
      "Bash(* /home/*/.aws*)",
      "Bash(* ~/.gnupg*)",
      "Bash(* ~/.docker/config*)",
      "Bash(* ~/.kube/config*)",
      "Bash(* ~/.netrc*)",
      "Bash(git config --global *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard origin*)",
      "Read(~/.ssh/**)",
      "Read(/Users/*/.ssh/**)",
      "Read(/home/*/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(/Users/*/.aws/**)",
      "Read(/home/*/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(/Users/*/.gnupg/**)",
      "Read(/home/*/.gnupg/**)",
      "Read(~/.docker/config*)",
      "Read(~/.kube/config*)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ecdsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",
      "Read(~/Library/Keychains/**)",
      "Read(/var/log/**)",
      "Edit(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.json)",
      "Write(.claude/settings.local.json)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.profile)",
      "Edit(~/.bash_profile)",
      "Edit(~/.gitconfig)",
      "Edit(/etc/**)",
      "Write(~/.bashrc)",
      "Write(~/.zshrc)",
      "Write(/etc/**)",
      "WebFetch(domain:169.254.169.254)"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm install*)",
      "Bash(npm i *)",
      "Bash(pnpm install*)",
      "Bash(yarn add*)",
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(brew install*)",
      "Bash(apt install*)",
      "Bash(apt-get install*)",
      "Bash(dnf install*)",
      "Bash(yum install*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(git clean -fd*)",
      "Bash(git remote *)",
      "Bash(git config *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(./gradlew clean*)",
      "Bash(./gradlew publish*)",
      "Bash(docker *)",
      "Bash(podman *)",
      "Bash(systemctl *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(nc *)",
      "Bash(netcat *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "WebFetch"
    ],
    "allow": [
      "Bash(./gradlew build)",
      "Bash(./gradlew bootRun)",
      "Bash(./gradlew test)",
      "Bash(./gradlew check)",
      "Bash(./gradlew tasks)",
      "Bash(./gradlew --version)",
      "Bash(./gradlew --help)",
      "Bash(./gradlew dependencies)",
      "Bash(./gradlew dependencies *)",
      "Bash(./gradlew compileJava)",
      "Bash(./gradlew compileTestJava)",
      "Bash(./gradlew test --tests *)",
      "Bash(./gradlew bootJar)",
      "Bash(java -version)",
      "Bash(javac -version)",
      "Bash(node -v)",
      "Bash(node --version)",
      "Bash(npm -v)",
      "Bash(npm --version)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git stash list)",
      "Bash(git stash show*)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git checkout -b *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(curl http://localhost:*)",
      "Bash(curl https://localhost:*)",
      "Bash(curl http://127.0.0.1:*)",
      "Bash(curl https://127.0.0.1:*)",
      "Bash(jcmd *)",
      "Bash(jps)",
      "Bash(jps *)",
      "Read(src/**)",
      "Read(build.gradle.kts)",
      "Read(settings.gradle.kts)",
      "Read(gradle.properties)",
      "Read(CLAUDE.md)",
      "Read(README.md)",
      "Read(*.md)"
    ]
  },
  "env": {
    "CLAUDE_CODE_TRAINING_PROJECT": "library-app",
    "CLAUDE_CODE_TRAINING_VERSION": "v1.0"
  }
}
